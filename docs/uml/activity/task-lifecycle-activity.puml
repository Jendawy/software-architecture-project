@startuml task-lifecycle-activity
!theme plain
skinparam shadowing false
skinparam defaultFontSize 11
skinparam activityDiamondBackgroundColor #FEFECE

title Task Management System - Activity Diagram\nTask Lifecycle

start

:Select Task Type;

if (Task Type?) then (Bug)
    :Create via BugTaskFactory;
elseif (Feature) then
    :Create via FeatureTaskFactory;
else (Documentation)
    :Create via DocumentationTaskFactory;
endif

:Add Task to TaskManager;

:Select Priority Strategy;

fork
    :UrgentFirstStrategy;
fork again
    :DeadlineFirstStrategy;
fork again
    :SeverityFirstStrategy;
end fork

:Get Prioritized Task List;

:Process Task;

if (Needs Review?) then (Yes)
    :Submit for Review;
    :Review Task;

    if (Approved?) then (Yes)
        :Mark as DONE;
    else (No)
        :Return to IN_PROGRESS;
        :Process Task;
        note right
            Task cycles back
            for rework
        end note
    endif
else (No)
    :Mark as DONE;
endif

stop

@enduml
