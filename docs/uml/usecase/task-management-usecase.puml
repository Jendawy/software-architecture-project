@startuml task-management-usecase
!theme plain
skinparam shadowing false
skinparam defaultFontSize 11
skinparam usecaseBackgroundColor #FEFECE
skinparam actorStyle awesome

title Task Management System - Use Case Diagram

left to right direction

actor "Project Manager" as PM

rectangle "Task Management System" {
    usecase "Create Bug Task" as UC_Bug
    usecase "Create Feature Task" as UC_Feature
    usecase "Create Documentation Task" as UC_Doc
    usecase "Validate Task Data" as UC_Validate
    usecase "View All Tasks" as UC_ViewAll
    usecase "View Tasks by Status" as UC_ViewStatus
    usecase "Prioritize Tasks\n(with Strategy)" as UC_Prioritize
    usecase "Change Task Status" as UC_ChangeStatus
    usecase "Handle Invalid\nTransition" as UC_InvalidTransition
    usecase "Remove Task" as UC_Remove
    usecase "Switch Priority\nStrategy" as UC_SwitchStrategy
}

PM --> UC_Bug
PM --> UC_Feature
PM --> UC_Doc
PM --> UC_ViewAll
PM --> UC_ViewStatus
PM --> UC_Prioritize
PM --> UC_ChangeStatus
PM --> UC_Remove
PM --> UC_SwitchStrategy

UC_Bug ..> UC_Validate : <<include>>
UC_Feature ..> UC_Validate : <<include>>
UC_Doc ..> UC_Validate : <<include>>

UC_ChangeStatus ..> UC_InvalidTransition : <<extend>>

@enduml
