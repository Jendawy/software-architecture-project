@startuml task-creation-sequence
!theme plain
skinparam shadowing false
skinparam defaultFontSize 11
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

title Task Management System - Sequence Diagram\nTask Creation and Prioritization

actor "Project Manager" as PM

participant "Main" as Main
participant "TaskManager" as TM
participant "factoryRegistry\n:Map<String,TaskFactory>" as Registry
participant "BugTaskFactory" as BTF
participant "BugTask" as BT
participant "DeadlineFirstStrategy" as DFS

== Task Creation ==

PM -> Main : createTask("BUG", "Fix login", "Login fails", 1)
activate Main

Main -> TM : createTask("BUG", "Fix login", "Login fails", 1)
activate TM

TM -> Registry : get("BUG")
activate Registry
Registry --> TM : bugTaskFactory
deactivate Registry

TM -> BTF : createTask("Fix login", "Login fails", 1)
activate BTF

BTF -> BT ** : new BugTask("Fix login", "Login fails", 1)
activate BT
BT --> BTF : bugTask
deactivate BT

BTF --> TM : bugTask
deactivate BTF

TM -> TM : tasks.add(bugTask)

TM --> Main : bugTask
deactivate TM

Main --> PM : Task created successfully
deactivate Main

== Prioritization ==

PM -> Main : setPriorityStrategy\n(new DeadlineFirstStrategy())
activate Main

Main -> TM : setPriorityStrategy(deadlineFirstStrategy)
activate TM
TM -> TM : currentStrategy = deadlineFirstStrategy
TM --> Main : void
deactivate TM

PM -> Main : getPrioritizedTasks()

Main -> TM : getPrioritizedTasks()
activate TM

TM -> DFS : sort(tasks)
activate DFS
DFS -> DFS : sort by deadline\n(earliest first)
DFS --> TM : sortedTasks
deactivate DFS

TM --> Main : sortedTasks
deactivate TM

Main --> PM : Display prioritized task list
deactivate Main

@enduml
